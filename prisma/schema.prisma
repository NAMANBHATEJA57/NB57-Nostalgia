generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication ────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Categories ────────────────────────────────────────────────

model Category {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String?  @db.Text
  bannerImage    String?
  thumbnailImage String?
  icon           String?
  sortOrder      Int      @default(0)
  featured       Boolean  @default(false)
  seoTitle       String?
  seoDescription String?  @db.Text
  items          Item[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Tags ──────────────────────────────────────────────────────

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  items     ItemTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

// ─── Items (Collectibles Inventory) ────────────────────────────

model Item {
  id             String   @id @default(cuid())
  sku            String   @unique // Auto-generated NB57-XXXX (Collection ID)
  slug           String   @unique
  name           String
  description    String   @db.Text
  specifications String?  @db.Text
  privateNotes   String?  @db.Text
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  subcategory    String?
  series         String?
  character      String?
  manufacturer   String?
  releaseYear    Int?
  country        String?
  language       String?
  material       String?
  edition        String?
  variant        String?
  finish         String?
  condition      String
  availability   String   @default("Available") // Available, Reserved, Sold, Not for Sale
  storageLocation String?

  // Pricing
  askingPrice      Float?
  fairValueMin     Float?
  fairValueMax     Float?
  highestSeenPrice Float?
  lowestSeenPrice  Float?
  lastSoldPrice    Float?
  priceConfidence  String?
  priceSource      String?

  // Purchase Info
  purchasePrice Float?
  purchaseDate  DateTime?

  // Sales Info (for Sold items)
  soldPrice Float?
  soldDate  DateTime?
  soldTo    String?

  notes String? @db.Text

  // Physical
  weight     Float?   // in grams
  dimensions String?  // LxWxH in cm

  // Flags
  featured       Boolean @default(false)
  showOnHomepage Boolean @default(false)
  trending       Boolean @default(false)
  recentlyAdded  Boolean @default(false)
  hideFromPublic Boolean @default(false)
  sealed         Boolean @default(false)
  rare           Boolean @default(false)
  limited        Boolean @default(false)
  promo          Boolean @default(false)
  duplicate      Boolean @default(false)
  hidden         Boolean @default(false)
  archived       Boolean @default(false)

  quantity   Int    @default(1)
  coverImage String

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  openGraphImage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images       Image[]
  itemTags     ItemTag[]
  priceHistory PriceHistory[]
  views        ItemView[]
  sales        Sale[]
  blogPosts    BlogRelatedItem[]
  invoiceItems InvoiceItem[]
  reservations Reservation[]
  quoteItems   QuoteItem[]
  leadItems    LeadItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([availability])
  @@index([featured])
  @@index([createdAt])
  @@index([archived])
  @@index([name])
}

// ─── Images ────────────────────────────────────────────────────

model Image {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String   @default("Extra") // Cover, Front, Back, Packaging, CloseUp, Damage, Extra
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
}

// ─── Price History ─────────────────────────────────────────────

model PriceHistory {
  id     String   @id @default(cuid())
  itemId String
  item   Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price  Float
  date   DateTime @default(now())
  source String?
  notes  String?
}

// ─── Item Views ────────────────────────────────────────────────

model ItemView {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
  ipAddress String?
}

// ─── Legacy Sales ──────────────────────────────────────────────

model Sale {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  salePrice Float
  saleDate  DateTime @default(now())
  platform  String?
  notes     String?
}

// ─── Customers ─────────────────────────────────────────────────

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?       @db.Text
  city         String?
  state        String?
  country      String?       @default("India")
  pin          String?
  gstNumber    String?
  notes        String?       @db.Text
  invoices     Invoice[]
  reservations Reservation[]
  quotes       Quote[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([name])
  @@index([phone])
  @@index([email])
}

// ─── Invoices ──────────────────────────────────────────────────

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique  // NB57-INV-YYYYMM-XXXX
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])

  // Totals
  subtotal        Float    @default(0)
  taxPercent       Float?
  taxAmount       Float    @default(0)
  discountPercent  Float?
  discountAmount  Float    @default(0)
  shippingCharge  Float    @default(0)
  packagingCharge Float    @default(0)
  miscCharge      Float    @default(0)
  grandTotal      Float    @default(0)

  // Payment
  paymentMethod   String?  // Cash, UPI, Bank
  paymentStatus   String   @default("Draft") // Paid, Pending, Partial, Cancelled, Draft
  amountPaid      Float    @default(0)

  // Extras
  notes           String?  @db.Text
  trackingNumber  String?
  courierName     String?

  // Relations
  items           InvoiceItem[]
  ledgerEntries   LedgerEntry[]
  timeline        InvoiceTimeline[]
  quotes          Quote[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ─── Invoice Items ─────────────────────────────────────────────

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item    @relation(fields: [itemId], references: [id])
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float

  // Snapshots for historical accuracy
  itemName    String
  itemSku     String
  itemCondition String?

  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@index([itemId])
}

// ─── Reservations ──────────────────────────────────────────────

model Reservation {
  id              String   @id @default(cuid())
  itemId          String
  item            Item     @relation(fields: [itemId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerName    String?  // For quick reservations without customer record
  customerPhone   String?
  reason          String?  @db.Text
  deposit         Float    @default(0)
  notes           String?  @db.Text
  reservationDate DateTime @default(now())
  expiryDate      DateTime // Default 48 hours from creation
  status          String   @default("Active") // Active, Expired, Converted, Cancelled

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([itemId])
  @@index([customerId])
  @@index([status])
  @@index([expiryDate])
}

// ─── Ledger ────────────────────────────────────────────────────

model LedgerEntry {
  id          String   @id @default(cuid())
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type        String   // Revenue, InventoryCost, Shipping, Packaging, Misc, Profit, Refund, Deletion
  amount      Float
  description String
  notes       String?  @db.Text
  reversed    Boolean  @default(false)
  reversedAt  DateTime?

  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@index([type])
  @@index([createdAt])
  @@index([reversed])
}

// ─── Invoice Timeline ──────────────────────────────────────────

model InvoiceTimeline {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  event     String   // Created, Edited, Draft, Reserved, Paid, Downloaded, WhatsAppShared, Packed, Shipped, Delivered, Completed, Deleted
  admin     String?
  notes     String?  @db.Text
  timestamp DateTime @default(now())

  // Never overwritten — append only
  @@index([invoiceId])
  @@index([timestamp])
}

// ─── Activity Log ──────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // Created, Updated, Deleted, StatusChanged, Exported, etc.
  entity    String   // Item, Invoice, Customer, Reservation, Category, Blog, etc.
  entityId  String?
  details   String?  @db.Text // JSON string for detailed changes
  admin     String?
  timestamp DateTime @default(now())

  @@index([entity])
  @@index([timestamp])
  @@index([entityId])
}

// ─── Blog System ───────────────────────────────────────────────

model BlogCategory {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?    @db.Text
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BlogTag {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  posts     BlogPostTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model BlogPost {
  id            String  @id @default(cuid())
  title         String
  slug          String  @unique
  excerpt       String? @db.Text
  content       String  @db.Text // HTML from Tiptap
  featuredImage String?
  author        String  @default("NB57's Nostalgia")

  // Settings & SEO
  status         String  @default("Draft") // Draft, Published, Scheduled
  featured       Boolean @default(false)
  pinned         Boolean @default(false)
  readingTime    Int?
  seoTitle       String?
  seoDescription String? @db.Text
  focusKeyword   String?
  schemaType     String  @default("Article") // Article, How-To, Guide, Collection, Review
  canonicalUrl   String?
  openGraphImage String?
  twitterImage   String?
  estimatedDifficulty String?

  // Metrics
  views Int @default(0)

  // Relations
  categoryId String
  category   BlogCategory @relation(fields: [categoryId], references: [id])

  tags           BlogPostTag[]
  relatedItems   BlogRelatedItem[]
  relatedPosts   BlogRelatedPost[] @relation("RelatedPostSource")
  relatedByPosts BlogRelatedPost[] @relation("RelatedPostTarget")
  comments       BlogComment[]

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([slug])
  @@index([featured])
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model BlogRelatedItem {
  postId String
  itemId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  item   Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([postId, itemId])
}

model BlogRelatedPost {
  sourcePostId String
  targetPostId String
  sourcePost   BlogPost @relation("RelatedPostSource", fields: [sourcePostId], references: [id], onDelete: Cascade)
  targetPost   BlogPost @relation("RelatedPostTarget", fields: [targetPostId], references: [id], onDelete: Cascade)

  @@id([sourcePostId, targetPostId])
}

model BlogComment {
  id          String   @id @default(cuid())
  postId      String
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String?
  content     String   @db.Text
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Calculator Quotes ─────────────────────────────────────────

model Quote {
  id              String   @id @default(cuid())
  title           String?  // Optional name for the calculation
  
  // Optional customer details (can be temporary text or link to Customer model)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerName    String?
  customerPhone   String?
  
  // Totals
  subtotal        Float    @default(0)
  discountPercent Float?
  discountAmount  Float    @default(0)
  shippingCharge  Float    @default(0)
  packagingCharge Float    @default(0)
  miscCharge      Float    @default(0)
  grandTotal      Float    @default(0)
  
  // Negotiation / Deal specific
  advancePaid     Float    @default(0)
  
  status          String   @default("Saved") // Saved, Converted
  notes           String?  @db.Text
  
  // Conversion to Invoice
  invoiceId       String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  convertedDate   DateTime?
  convertedBy     String?
  
  items           QuoteItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([invoiceId])
}

model QuoteItem {
  id            String  @id @default(cuid())
  quoteId       String
  quote         Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item    @relation(fields: [itemId], references: [id])
  quantity      Int     @default(1)
  
  // Snapshots for the quote
  itemName      String
  itemSku       String
  itemCondition String?
  askingPrice   Float   @default(0)
  sellingPrice  Float   @default(0)
  
  createdAt     DateTime @default(now())
  
  @@index([quoteId])
  @@index([itemId])
}

// ─── WhatsApp Inquiry Leads ────────────────────────────────────

model Lead {
  id             String   @id @default(cuid())
  leadNumber     String   @unique  // NB57-LD-YYYYMM-XXXX
  date           DateTime @default(now())
  
  // Buyer Details
  buyerName      String
  phone          String
  city           String?
  state          String?
  country        String?  @default("India")
  email          String?
  notes          String?  @db.Text
  
  estimatedValue Float    @default(0)
  status         String   @default("New") // New, Contacted, Negotiating, Reserved, Converted, Lost
  
  items          LeadItem[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

model LeadItem {
  id            String  @id @default(cuid())
  leadId        String
  lead          Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item    @relation(fields: [itemId], references: [id])
  
  // Snapshots for the inquiry
  itemName      String
  itemSku       String
  itemCondition String?
  estimatedPrice Float  @default(0)
  
  createdAt     DateTime @default(now())
  
  @@index([leadId])
  @@index([itemId])
}

